{
  "name": "spotify-overlayer",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --windows"
  },
  "dependencies": {
    "axios": "^1.7.2"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.kljj04.spotifyoverlayer",
    "productName": "SpotifyOverlayer",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "files": [
      "main.js",
      "render/**/*"
    ]
  }
}